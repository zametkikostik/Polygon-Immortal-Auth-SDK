# ============================================
# Polygon Immortal Auth SDK - .gitignore
# ============================================
# Игнорируемые файлы и директории для Git
# ============================================

# --------------------------------------------
# ENVIRONMENT & SECRETS
# --------------------------------------------
# Никогда не коммитить конфиденциальные данные!
.env
.env.local
.env.production
.env.development
*.env

# --------------------------------------------
# DEPENDENCIES
# --------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# --------------------------------------------
# BUILD ARTIFACTS
# --------------------------------------------
# Capacitor build
www/
capacitor/www/
capacitor/node_modules/

# Android build
android/app/build/
android/.gradle/
android/build/
*.apk
*.aab
*.ap_
*.dex
*.class

# Gradle
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# --------------------------------------------
# IDE & EDITORS
# --------------------------------------------
.vscode/
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --------------------------------------------
# OS FILES
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --------------------------------------------
# LOGS
# --------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --------------------------------------------
# TEST & COVERAGE
# --------------------------------------------
coverage/
.nyc_output/
*.lcov
.jest/

# --------------------------------------------
# TEMPORARY FILES
# --------------------------------------------
tmp/
temp/
.cache/
.parcel-cache/
.next/
out/

# --------------------------------------------
# IPFS & DEPLOYMENT
# --------------------------------------------
# Локальные IPFS хэши
.ipfs/
pinata.json

# --------------------------------------------
# BACKUP FILES
# --------------------------------------------
*.bak
*.backup
*.old
*~

# --------------------------------------------
# DOCUMENTATION (опционально)
# --------------------------------------------
# Если не хотите хранить локальные копии
# docs/_build/
# site/

# --------------------------------------------
# MISC
# --------------------------------------------
# Токены и ключи доступа
*.pem
*.key
*.crt
*.p12
*.pfx

# Docker (если не используется)
docker-compose.override.yml

# Vercel
.vercel

# Netlify
.netlify
