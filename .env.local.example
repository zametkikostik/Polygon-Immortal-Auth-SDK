# ============================================
# Polygon Immortal Auth SDK - Environment
# ============================================
# Скопируйте этот файл в .env.local и заполните своими данными
# .env.local НЕ должен коммититься в Git (добавлен в .gitignore)
# ============================================

# --------------------------------------------
# SMART CONTRACT
# --------------------------------------------
# Адрес развёрнутого контракта ImmortalWeb32FA
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# --------------------------------------------
# BICONOMY CONFIG
# --------------------------------------------
# Получите в https://dashboard.biconomy.io
BICONOMY_API_KEY=your_biconomy_api_key_here
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/59140/your-paymaster-key

# --------------------------------------------
# NETWORK CONFIG
# --------------------------------------------
# Polygon Mainnet
CHAIN_ID=137
RPC_URL=https://polygon-rpc.com

# Для тестирования (раскомментировать)
# CHAIN_ID=80001
# RPC_URL=https://rpc-mumbai.maticvigil.com

# --------------------------------------------
# IPFS CONFIG
# --------------------------------------------
# Публичный шлюз
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Для продакшена (Pinata)
# IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# PINATA_API_KEY=your_pinata_api_key
# PINATA_SECRET_KEY=your_pinata_secret_key

# --------------------------------------------
# PLATFORM CONFIG
# --------------------------------------------
# Адрес для сбора комиссий платформы (1% от активации)
PLATFORM_ADDRESS=0x0000000000000000000000000000000000000000

# --------------------------------------------
# BUSINESS CODES (для B2B)
# --------------------------------------------
# Формат: CODE=BUSINESS_ADDRESS
# Добавьте коды ваших бизнес-клиентов
BUSINESS_CODE_ACME=0x1234567890123456789012345678901234567890
BUSINESS_CODE_CORP=0xabcdefabcdefabcdefabcdefabcdefabcdefabcd

# --------------------------------------------
# ACTIVATION FEE
# --------------------------------------------
# Сумма активации в POL (должна совпадать с контрактом)
ACTIVATION_FEE_POL=2

# --------------------------------------------
# APP CONFIG
# --------------------------------------------
# Название приложения
APP_NAME=Polygon Immortal Auth
APP_VERSION=1.0.0

# --------------------------------------------
# DEBUG MODE
# --------------------------------------------
# true для разработки, false для продакшена
DEBUG_MODE=true
